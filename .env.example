# Pooled Neon connection string. Keep the real value in .env only.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Restricted login created by `pnpm db:setup-app-role`.
DATABASE_APP_URL=""

# Phase 2: required when Neon Auth is enabled in the Neon console.
NEON_AUTH_BASE_URL=""
NEON_AUTH_COOKIE_SECRET=""

# Bekræft eksplicit, at db:seed kun må skrive development-data lokalt.
ALLOW_DEVELOPMENT_SEED="false"

# Vercel Blob: separat offentlig store til annoncebilleder.
LISTING_IMAGES_BLOB_READ_WRITE_TOKEN=""

# Vercel Blob: separat privat store til alle følsomme dokumenter.
PRIVATE_DOCUMENTS_BLOB_READ_WRITE_TOKEN=""

# Midlertidig fallback for ældre miljøer. Kan fjernes efter variablen ovenfor
# er sat i Development, Preview og Production.
OWNERSHIP_DOCUMENTS_BLOB_READ_WRITE_TOKEN=""

# Offentlig produktionsadresse og supportkontakt til metadata/legal-sider.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SUPPORT_EMAIL=""
